# BizCore Environment Configuration Template
# Copy this to .env and fill in your actual values
# DO NOT COMMIT .env to version control

# ====== DATABASE ======
# SQLite Configuration (default)
DATABASE_URL="file:./dev.db"

# PostgreSQL Configuration (optional, if using external DB)
# DATABASE_URL="postgresql://postgres:password@localhost:5432/bizcore_dev?schema=public"
# DB_PASSWORD=your_secure_postgres_password_here
# POSTGRES_DB=bizcore_dev
# POSTGRES_USER=postgres

# ====== PGADMIN (optional) ======
# PGADMIN_EMAIL=admin@bizcore.dev
# PGADMIN_PASSWORD=your_secure_pgadmin_password_here

# ====== NEXT.JS ======
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here_min_32_chars
NEXTAUTH_URL=http://localhost:3000

# ====== DOMAIN & SSL ======
DOMAIN=localhost
# For production, set to your actual domain: bizcore.dev
# SSL_EMAIL for Let's Encrypt

# ====== OPTIONAL SERVICES ======
# REDIS_URL=redis://localhost:6379
# STRIPE_SECRET_KEY=sk_test_...
# GITHUB_ID=your_github_oauth_id
# GITHUB_SECRET=your_github_oauth_secret

# ====== FEATURE FLAGS ======
ENABLE_ADMIN_TEMPLATES=true
ENABLE_RATE_LIMITING=true
ENABLE_HTTPS_REDIRECT=false  # Set to true when SSL ready
ENABLE_CORS=true

# ====== LOGGING ======
LOG_LEVEL=info
# Values: debug, info, warn, error

# ====== SECURITY ======
CORS_ORIGIN=http://localhost:3000,http://localhost:5174
SECURE_HEADERS=true
RATE_LIMIT_WINDOW=60000  # milliseconds
RATE_LIMIT_MAX_REQUESTS=100  # per window

# ====== DEVELOPMENT ONLY ======
# Remove these in production!
DEBUG=false
MOCK_AUTH=false  # Don't set to true in production
ALLOW_INSECURE_ORIGIN=false

# ====== SMTP (for email notifications) ======
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=noreply@bizcore.dev

# ====== BACKUP & STORAGE ======
# BACKUP_BUCKET=bizcore-backups
# BACKUP_FREQUENCY=daily
# STORAGE_PROVIDER=local  # or: s3, gcs

# ====== MONITORING & ANALYTICS ======
# SENTRY_DSN=https://your_sentry_dsn@sentry.io/project
# GA_TRACKING_ID=UA-XXXXXXXXX-X
# DATADOG_API_KEY=your_datadog_key
