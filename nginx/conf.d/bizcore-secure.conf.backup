 #============================================================
 #BizCore Security-Hardened Nginx Configuration
 #============================================================
 HTTP Redirect to HTTPS (remove this if HTTPS not ready)
server {
     listen 80;
     server_name _;
     return 301 https://$host$request_uri;
}

 #============================================================
 # HTTPS Main Server (Uncomment when SSL certificates ready)
 #============================================================
 server {
     listen 443 ssl http2;
     server_name localhost;  # Change to your domain

      ====== SSL/TLS CERTIFICATES ======
     ssl_certificate /etc/nginx/ssl/cert.pem;
     ssl_certificate_key /etc/nginx/ssl/key.pem;

      #====== SSL/TLS HARDENING ======
     ssl_protocols TLSv1.2 TLSv1.3;
     ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
     ssl_prefer_server_ciphers on;
     ssl_ecdh_curve auto;
     ssl_session_cache shared:SSL:10m;
     ssl_session_timeout 10m;
     ssl_session_tickets off;

     # OCSP Stapling (optional, requires additional setup)
     # ssl_stapling on;
     # ssl_stapling_verify on;
     # ssl_trusted_certificate /etc/nginx/ssl/chain.pem;
     # resolver 8.8.8.8 8.8.4.4;

      #====== SECURITY HEADERS (overrides main config) ======
     add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
     add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https:;" always;
     add_header X-Frame-Options "SAMEORIGIN" always;
     add_header X-Content-Type-Options "nosniff" always;
     add_header X-XSS-Protection "1; mode=block" always;
     add_header Referrer-Policy "strict-origin-when-cross-origin" always;
     add_header Permissions-Policy "geolocation=(), microphone=(), camera=()" always;

     access_log /var/log/nginx/bizcore.access.log main;
     error_log /var/log/nginx/bizcore.error.log;
 }

# ============================================================
# HTTP Server (Development/Local Setup)
# ============================================================
server {
    listen 80;
    server_name localhost;  # Change to your domain or IP

    access_log /var/log/nginx/bizcore.access.log main;
    error_log /var/log/nginx/bizcore.error.log warn;

    # ====== SECURITY HEADERS ======
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "geolocation=(), microphone=(), camera=()" always;

    # ====== BODY SIZE LIMIT ======
    client_max_body_size 10m;

    # ====== BRANDSTUDIO (Static Vite Build) ======
    location /brandstudio/ {
        alias /usr/share/nginx/html/brandstudio/;
        index index.html;
        try_files $uri $uri/ /brandstudio/index.html;
        access_log /var/log/nginx/brandstudio.access.log main;
        error_log /var/log/nginx/brandstudio.error.log;

        # Cache static assets for 7 days
        location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
            expires 7d;
            add_header Cache-Control "public, immutable";
            access_log off;
        }

        # Don't cache HTML files
        location ~* \.html?$ {
            expires -1;
            add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate";
        }
    }

    # ====== NEXT.JS BACKEND WITH SECURITY ======
    location / {
        # Apply rate limiting
        limit_req zone=general burst=50 nodelay;

        proxy_pass http://bizcore_backend;
        proxy_http_version 1.1;

        # ====== PROXY HEADERS ======
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;

        # ====== CONNECTION SETTINGS ======
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
        proxy_connect_timeout 10s;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_buffering on;
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;
        proxy_busy_buffers_size 8k;

        # ====== ERROR HANDLING ======
        proxy_intercept_errors on;
    }

    # ====== API ENDPOINTS (STRICTER RATE LIMIT) ======
    location ~ ^/api/ {
        limit_req zone=api burst=20 nodelay;

        proxy_pass http://bizcore_backend;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_read_timeout 30s;
        proxy_send_timeout 30s;
        proxy_connect_timeout 10s;
    }

    # ====== AUTHENTICATION ENDPOINTS (STRICTEST RATE LIMIT) ======
    location ~ ^/(api/auth|auth/) {
        limit_req zone=login burst=5 nodelay;

        proxy_pass http://bizcore_backend;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_read_timeout 30s;
        proxy_send_timeout 30s;
        proxy_connect_timeout 10s;
    }

    # ====== STATIC ASSETS OPTIMIZATION ======
    location ~* \.(jpg|jpeg|png|gif|ico|css|js|svg|woff|woff2|ttf|eot)$ {
        expires 7d;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # ====== DENY ACCESS TO SENSITIVE FILES ======
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    location ~ ~$ {
        deny all;
        access_log off;
        log_not_found off;
    }

    location ~ /node_modules/ {
        deny all;
        access_log off;
        log_not_found off;
    }

    # ====== DENY ACCESS TO COMMON VULNERABILITIES ======
    location ~ /(wp-admin|wp-login|xmlrpc\.php|config\.php|admin\.php) {
        deny all;
        access_log off;
        log_not_found off;
    }

    # ====== ERROR PAGES ======
    error_page 404 /404.html;
    location = /404.html {
        root /usr/share/nginx/html/brandstudio;
        internal;
    }

    error_page 500 502 503 504 /50x.html;
    location = /50x.html {
        root /usr/share/nginx/html/brandstudio;
        internal;
    }

    # ====== HEALTH CHECK (for monitoring) ======
    location /health {
        access_log off;
        return 200 "healthy\n";
        add_header Content-Type text/plain;
    }
}

