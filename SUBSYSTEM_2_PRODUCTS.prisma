generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// SUBSYSTEM 2: PRODUCTS & CATALOG (includes dependencies from Subsystem 1)
// ============================================================================

model Tenant {
  id                    Int                    @id @default(autoincrement())
  name                  String
  subdomain             String                 @unique
  domain                String?
  description           String?
  ownerId               Int
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @default(now())

  categories            Category[]
  products              Product[]
  ingredients           Ingredient[]

  @@map("tenants")
}

model Category {
  id          Int       @id @default(autoincrement())
  tenantId    Int
  name        String
  description String?
  image       String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now())

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products    Product[]

  @@map("categories")
}

model Product {
  id                 Int                 @id @default(autoincrement())
  tenantId           Int
  categoryId         Int?
  name               String
  description        String?
  price              Float
  cost               Float               @default(0)
  image              String?
  isActive           Boolean             @default(true)
  isFeatured         Boolean             @default(false)
  sortOrder          Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @default(now())
  slug                String?
  currentStock       Float               @default(0)
  lowStockThreshold  Float               @default(10)
  trackInventory     Boolean             @default(false)

  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category            Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  productIngredients  ProductIngredient[]
  productVariants     ProductVariant[]

  @@map("products")
}

model ProductVariant {
  id                 Int                 @id @default(autoincrement())
  productId          Int
  name               String
  price              Float
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @default(now())

  product            Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantIngredients VariantIngredient[]

  @@map("product_variants")
}

model Ingredient {
  id                    Int                    @id @default(autoincrement())
  tenantId              Int
  name                  String
  description           String?
  unit                  String                 @default("pieces")
  currentStock          Float                  @default(0)
  minStock              Float                  @default(0)
  costPerUnit           Float                  @default(0)
  supplier              String?
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @default(now())
  reservedStock         Float                  @default(0)

  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productIngredients    ProductIngredient[]
  variantIngredients    VariantIngredient[]

  @@map("ingredients")
}

model ProductIngredient {
  id           Int        @id @default(autoincrement())
  productId    Int
  ingredientId Int
  quantity     Float

  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([productId, ingredientId])
  @@map("product_ingredients")
}

model VariantIngredient {
  id           Int            @id @default(autoincrement())
  variantId    Int
  ingredientId Int
  quantity     Float
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @default(now())

  variant      ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  ingredient   Ingredient     @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([variantId, ingredientId])
  @@map("variant_ingredients")
}