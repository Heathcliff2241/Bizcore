generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMERATIONS
// ============================================================================

enum SubscriptionStatus {
  trial
  active
  paused
  overdue
  cancelled
  expired
  suspended
}

enum BillingCycle {
  monthly
  annual
  lifetime
  trial
}

enum UpgradeStatus {
  pending
  payment_submitted
  approved
  applied
  cancelled
  expired
}

enum PaymentStatus {
  unpaid
  partial
  paid
  refunded
}

enum InvoiceStatus {
  draft
  issued
  paid
  partial
  failed
  refunded
}

// ============================================================================
// SUBSYSTEM 7: SUBSCRIPTION & BILLING (includes dependencies from Subsystem 1)
// ============================================================================

model Tenant {
  id        Int       @id @default(autoincrement())
  name      String
  subdomain String    @unique
  createdAt DateTime  @default(now())

  subscriptions       Subscription[]
  billingPreferences  BillingPreference[]
  planUpgradeRequests PlanUpgradeRequest[]

  @@map("tenants")
}

model Plan {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  price       Float
  billingCycle BillingCycle @default(monthly)
  features    Json?
  isActive    Boolean   @default(true)
  displayOrder Int      @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now())

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id              Int       @id @default(autoincrement())
  tenantId        Int
  planId          Int
  status          SubscriptionStatus @default(trial)
  billingCycle    BillingCycle
  periods         Int       @default(1)
  renewalDate     DateTime?
  autoRenew       Boolean   @default(true)
  unusedBalance   Float     @default(0)
  pendingUpgradeId Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now())
  cancellationDate DateTime?

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan            Plan      @relation(fields: [planId], references: [id], onDelete: Restrict)
  invoices        Invoice[]
  payments        Payment[]
  usageRecords    UsageRecord[]
  upgradeRequest  PlanUpgradeRequest?

  @@unique([tenantId, planId])
  @@map("subscriptions")
}

model Invoice {
  id              Int       @id @default(autoincrement())
  subscriptionId  Int
  invoiceNumber   String
  status          InvoiceStatus @default(issued)
  subtotal        Float
  tax             Float     @default(0)
  discount        Float     @default(0)
  total           Float
  dueDate         DateTime?
  paidAt          DateTime?
  lineItems       Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now())

  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  payments        Payment[]

  @@unique([subscriptionId, invoiceNumber])
  @@map("invoices")
}

model Payment {
  id              Int       @id @default(autoincrement())
  subscriptionId  Int
  invoiceId       Int?
  status          PaymentStatus @default(unpaid)
  amount          Float
  currency        String    @default("USD")
  paymentMethod   String?
  cardBrand       String?
  cardLastFour    String?
  gatewayId       String?
  gatewayResponse Json?
  retryCount      Int       @default(0)
  failureReason   String?
  idempotencyKey  String?
  expiresAt       DateTime?
  verifiedAt      DateTime?
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now())

  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  invoice         Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  upgradeRequest  PlanUpgradeRequest?

  @@map("payments")
}

model UsageRecord {
  id              Int       @id @default(autoincrement())
  subscriptionId  Int
  metric          String
  value           Float
  limit           Float?
  percentageUsed  Float?
  recordedAt      DateTime  @default(now())

  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("usage_records")
}

model BillingPreference {
  id              Int       @id @default(autoincrement())
  tenantId        Int       @unique
  notifyBeforeRenewal Boolean @default(true)
  billingEmail    String?
  billingAddress  Json?
  taxId           String?
  autoRenew       Boolean   @default(true)
  gcashPhoneNumber String?
  gcashQrCodeUrl  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now())

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("billing_preferences")
}

model PlanUpgradeRequest {
  id              Int       @id @default(autoincrement())
  tenantId        Int
  subscriptionId  Int       @unique
  currentPlanId   Int?
  newPlanId       Int?
  status          UpgradeStatus @default(pending)
  amountDue       Float
  prorationDetails Json?
  paymentId       Int?
  paymentLink     String?
  approvalNotes   String?
  requestedAt     DateTime  @default(now())
  expiresAt       DateTime?
  appliedAt       DateTime?

  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  payment         Payment?    @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@map("plan_upgrade_requests")
}

model AdminSettings {
  id                      Int       @id @default(autoincrement())
  adminGcashPhoneNumber   String?
  adminGcashAccountName   String?
  adminGcashQrCodeUrl     String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @default(now())

  @@map("admin_settings")
}