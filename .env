# ============================================================
# LOCAL DEVELOPMENT - uses SQLite (no Docker required)
# ============================================================
DATABASE_URL="file:./dev.db"

# NextAuth - Local development configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="AB9WGL7qOdAEjjiddBNq/jHImha995xz8QoyYYxhnYg="

# App URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# NEXT_PUBLIC_BRANDSTUDIO_URL="http://localhost:3000/brandstudio" (BrandStudio disabled)

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Other
NODE_ENV="development"

# ============================================================
# VERCEL DEPLOYMENT - set these in your Vercel project settings
# Dashboard → Your Project → Settings → Environment Variables
# ============================================================
#
# DATABASE_URL     = The "Transaction" connection string from Vercel Postgres (Neon)
#                    e.g. postgres://user:pass@ep-xxx.pooler.us-east-1.aws.neon.tech/neondb?sslmode=require
#
# DIRECT_URL       = The "Direct" connection string from Vercel Postgres (Neon)
#                    e.g. postgres://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
#                    (Required for Prisma migrations to work correctly with connection pooling)
#
# NEXTAUTH_URL     = Your Vercel app URL, e.g. https://your-project.vercel.app
#                    If using a custom domain: https://yourdomain.com
#
# NEXTAUTH_SECRET  = A long random string. Generate with: openssl rand -base64 32
#
# NEXT_PUBLIC_APP_URL = Same as NEXTAUTH_URL
#
# NODE_ENV         = production  (Vercel sets this automatically)