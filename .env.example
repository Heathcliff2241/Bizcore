# Environment Variables
# Copy this file to .env.local and fill in your values

# Database (SQLite)
DATABASE_URL="file:./dev.db"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-here-change-this-in-production"
NEXTAUTH_COOKIE_DOMAIN="" # Optional: set to .bizcore.test for cross-subdomain cookies
NEXTAUTH_COOKIE_SECURE="true" # Set to true in production (HTTPS)

# Development URLs
BRANDSTUDIO_URL="http://localhost:5174"
PGADMIN_URL="http://localhost:5050"
PGADMIN_DEFAULT_EMAIL="admin@bizcore.dev"
PGADMIN_DEFAULT_PASSWORD="admin123"

# Node Environment
NODE_ENV="development"

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Other
NODE_ENV="development"